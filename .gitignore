# ─────────────────────────────────────────────────────────────
# AI Governance Gateway — .gitignore
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js
.npm

# Secrets & environment (NEVER commit real secrets — use .env.example)
.env
.env.*
!.env.example
*.pem
*.key

# Build output
dist/
build/
*.tsbuildinfo
apps/admin-dashboard/dist/
apps/backend-gateway/dist/
apps/aigg-mcp/dist/
apps/vscode-extension/dist/

# Packaged VS Code extension
*.vsix

# Node-RED runtime state (auto-seeded from apps/aigg-mcp/node-red-flow.sample.json)
apps/node-red/data/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Internal specs / docs (kept out of the public repo)
docs/

# Test & coverage
coverage/
.nyc_output/
*.lcov

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# Misc
.cache/
tmp/
*.local
