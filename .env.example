# =============================================================
#  AI Governance Gateway — Environment template
#  Copy file này thành `.env` rồi điền giá trị thật:
#     cp .env.example .env
#  KHÔNG commit file `.env` (đã được .gitignore loại trừ).
# =============================================================

# ---- Mã hóa nội bộ (đổi thành chuỗi ngẫu nhiên mạnh) --------
# Dùng để mã hóa token tích hợp (AES-256-GCM) & ký dữ liệu nội bộ.
APP_SECRET="change-me-to-a-long-random-string"
CREDENTIAL_SECRET="change-me-to-another-long-random-string"

# ---- Redis -------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=admin
REDIS_PASSWORD=change-me-redis-password
REDIS_AUTH_PASSWORD=change-me-redis-auth-password

# ---- MySQL -------------------------------------------------
MYSQL_CONNECTION=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_governance_gateway
MYSQL_USERNAME=aigg_user
MYSQL_PASSWORD=change-me-mysql-password

# ---- Backend Gateway runtime -------------------------------
NODE_ENV=development
BACKEND_PORT=3900
# true ở lần chạy đầu để tự tạo bảng + nạp dữ liệu seed. Production nên đặt false sau khi DB ổn định.
DB_SYNC=true
DB_SEED=true

# ---- Master API Key của doanh nghiệp (Pay-as-you-go) -------
# Đây là khóa thật trả tiền cho OpenAI/Anthropic. TUYỆT ĐỐI không để lộ ra client.
OPENAI_API_KEY=sk-replace-with-your-openai-master-key
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-replace-with-your-anthropic-master-key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ---- Local LLM (self-hosted, OpenAI-compatible) ------------
# Định tuyến model có tiền tố ollama/ , vllm/ , local/ tới engine nội bộ.
# Ollama: http://localhost:11434/v1  |  vLLM: http://localhost:8000/v1
# Lợi ích: source/prompt không rời hạ tầng, chi phí API = 0, vẫn đủ quota + audit + ROI.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# Ollama bỏ trống; vLLM thường cần một Bearer token bất kỳ.
LOCAL_LLM_API_KEY=

# ---- Đăng nhập Admin Dashboard (JWT) -----------------------
JWT_SECRET=change-me-please-super-secret
JWT_EXPIRES_IN=12h

# ---- ROI: tỷ giá USD -> VND khi không gọi được API realtime
USD_TO_VND_FALLBACK=25400

# ---- API key cho hệ thống bên thứ ba gọi vào outbound API --
INTEGRATION_API_KEY=change-me-integration-api-key

# ---- Tài khoản admin seed lần đầu (nếu chưa tồn tại) -------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-admin-password

# ---- Frontend (Vite) ---------------------------------------
VITE_API_BASE_URL=http://localhost:3900

# ---- Node-RED bridge (tùy chọn, dùng cho MCP) --------------
NODE_RED_PORT=1880
NODE_RED_ADMIN_ROOT=/mdw
NODE_RED_CREDENTIAL_SECRET=change-me-node-red-secret
AIGG_GATEWAY_URL=http://localhost:3900
# Regex bóc Task ID từ tên git branch (vd: feature/AIGG-123-... -> 123)
AIGG_BRANCH_REGEX=(?:^|[/_-])(?:AIGG-)?(\d+)
